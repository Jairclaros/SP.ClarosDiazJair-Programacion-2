      <Button fx:id="btnAgregarProducto" layoutX="34.0" layoutY="298.0" mnemonicParsing="false" onAction="#agregar" prefHeight="56.0" prefWidth="138.0" text="Agregar" />
      <Button fx:id="btnModificarProducto" layoutX="232.0" layoutY="298.0" mnemonicParsing="false" onAction="#modificar" prefHeight="56.0" prefWidth="138.0" text="Modificar" />
      <Button fx:id="btnEliminarProducto" layoutX="429.0" layoutY="298.0" mnemonicParsing="false" onAction="#eliminar" prefHeight="56.0" prefWidth="138.0" text="Eliminar" />
